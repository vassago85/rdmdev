# RDM Developments - Production Environment
# Copy this file to .env in the project root and fill in the values.
# Generate APP_KEY after first container build with:
#   docker compose -f docker-compose.prod.yml exec app php artisan key:generate

#===============================================================================
# APPLICATION
#===============================================================================
APP_NAME="RDM Developments"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Africa/Johannesburg
APP_URL=https://rdmdev.co.za

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_ZA

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

#===============================================================================
# DATABASE (MySQL)
#===============================================================================
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=rdmdev
DB_USERNAME=rdmdev
# Generate strong passwords: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME
DB_ROOT_PASSWORD=CHANGE_ME_TOO

#===============================================================================
# CACHE, SESSION, QUEUE
#===============================================================================
CACHE_STORE=database
CACHE_PREFIX=
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=database

#===============================================================================
# LOGGING
#===============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

#===============================================================================
# FILESYSTEM (local public disk, persisted via Docker volume)
#===============================================================================
FILESYSTEM_DISK=public

#===============================================================================
# MAIL (set to SMTP for production; log driver for staging)
#===============================================================================
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@rdmdev.co.za"
MAIL_FROM_NAME="${APP_NAME}"

#===============================================================================
# TRUSTED PROXIES (for Nginx Proxy Manager)
#===============================================================================
TRUSTED_PROXIES=*

#===============================================================================
# VITE
#===============================================================================
VITE_APP_NAME="${APP_NAME}"

#===============================================================================
# RDM brand / contact (consumed via config/rdm.php)
#===============================================================================
RDM_PHONE="072 972 9393"
RDM_PHONE_TEL="+27729729393"
RDM_WHATSAPP="27729729393"
RDM_EMAIL="ruben@rdmdev.co.za"
RDM_ENQUIRY_TO="ruben@rdmdev.co.za"
RDM_OWNER="Ruben Metcalfe"
RDM_LOCATION="Pretoria East, Gauteng"
